JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# 本番では production にすると API の 500 応答に内部エラー詳細を含めません
# NODE_ENV=production

# ブラウザのオリジンをカンマ区切りで指定すると CORS を制限（例: http://localhost:3000）
# 未設定時は開発向けにすべてのオリジンを許可
# CORS_ORIGIN=http://localhost:3000

# リバースプロキシ配下でレート制限の IP を正しく扱う場合
# TRUST_PROXY=1

# PostgreSQL（未設定や空だと接続エラー／認証失敗になります。必ず文字列で設定）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pmo
DB_USER=pmo
DB_PASSWORD=your_postgres_password

# メール設定 (Gmail例)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=your_email@gmail.com

# 操作履歴メール通知: クライアント「通知設定」で有効化（未設定時は送信されません）
